{
  "name": "enri-media-sound-alert",
  "displayName": "Enri-Media Sound Alert",
  "description": "Enri-Media: Plays a sound when your code crashes — detects terminal run errors via exit codes. Supports Python, Node.js, Java, C, C++ and more.",
  "version": "1.0.4",
  "publisher": "GowthamGowdaCB",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Gowtham-314/darshan-horse-sound"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Other"],
  "keywords": ["error", "sound", "alert", "terminal", "python", "java", "nodejs"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "errorSoundAlert.toggle",
        "title": "Enri-Media Sound Alert: Toggle On/Off"
      },
      {
        "command": "errorSoundAlert.test",
        "title": "Enri-Media Sound Alert: Test Sound 🔊"
      }
    ],
    "configuration": {
      "title": "Enri-Media Sound Alert",
      "properties": {
        "errorSoundAlert.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the error sound alert. Only triggers when running code in the terminal fails (non-zero exit code)."
        },
        "errorSoundAlert.cooldownMs": {
          "type": "number",
          "default": 2000,
          "description": "Minimum milliseconds between two consecutive sound plays (prevents sound spam on repeated errors)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0"
  }
}
